            <Component class="javax.swing.JLabel" name="firstTheoryLabel">
              <Properties>
                <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                  <Font name="Segoe UI" size="14" style="0"/>
                </Property>
                <Property name="text" type="java.lang.String" value="&lt;html&gt;&#xa;&#xa;&#x412; &#x440;&#x435;&#x43b;&#x44f;&#x446;&#x438;&#x43e;&#x43d;&#x43d;&#x44b;&#x445; &#x421;&#x423;&#x411;&#x414; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x435; &#x43f;&#x440;&#x435;&#x434;&#x441;&#x442;&#x430;&#x432;&#x43b;&#x435;&#x43d;&#x44b; &#x432; &#x432;&#x438;&#x434;&#x435; &lt;b&gt;&#x442;&#x430;&#x431;&#x43b;&#x438;&#x446;&lt;/b&gt;. &lt;br&gt;&#x422;&#x430;&#x431;&#x43b;&#x438;&#x446;&#x44b; &#x432; &#x441;&#x432;&#x43e;&#x44e; &#x43e;&#x447;&#x435;&#x440;&#x435;&#x434;&#x44c; &#x441;&#x43e;&#x441;&#x442;&#x43e;&#x44f;&#x442; &#x438;&#x437; &lt;b&gt;&#x441;&#x442;&#x43e;&#x43b;&#x431;&#x446;&#x43e;&#x432;&lt;/b&gt; &#x438; &lt;b&gt;&#x441;&#x442;&#x440;&#x43e;&#x43a;&lt;/b&gt;.&#xa;&lt;br&gt;&lt;b&gt;&#x421;&#x442;&#x43e;&#x43b;&#x431;&#x446;&#x44b;&lt;/b&gt; &#x43e;&#x43f;&#x440;&#x435;&#x434;&#x435;&#x43b;&#x44f;&#x44e;&#x442; &lt;b&gt;&#x441;&#x442;&#x440;&#x443;&#x43a;&#x442;&#x443;&#x440;&#x443; &#x442;&#x430;&#x431;&#x43b;&#x438;&#x446;&#x44b;&lt;/b&gt;, &#x430; &lt;b&gt;&#x432; &#x441;&#x442;&#x440;&#x43e;&#x43a;&#x430;&#x445;&lt;/b&gt; &#x443;&#x436;&#x435; &#x445;&#x440;&#x430;&#x43d;&#x438;&#x442;&#x441;&#x44f; &lt;b&gt;&#x438;&#x43d;&#x444;&#x43e;&#x440;&#x43c;&#x430;&#x446;&#x438;&#x44f;&lt;/b&gt;.&#xa;&lt;br&gt;&lt;br&gt;&#x412;&#x44b;&#x431;&#x435;&#x440;&#x435;&#x43c; &#x43f;&#x440;&#x435;&#x434;&#x43c;&#x435;&#x442;&#x43d;&#x443;&#x44e; &#x43e;&#x431;&#x43b;&#x430;&#x441;&#x442;&#x44c; - &#x431;&#x438;&#x431;&#x43b;&#x438;&#x43e;&#x442;&#x435;&#x43a;&#x430; &#x438; &#x441;&#x43e;&#x437;&#x434;&#x430;&#x434;&#x438;&#x43c; &#x442;&#x430;&#x431;&#x43b;&#x438;&#x446;&#x443; Books.&#xa;&lt;br&gt;&#x422;&#x43e;&#x433;&#x434;&#x430; &#x442;&#x430;&#x431;&#x43b;&#x438;&#x446;&#x430; &#x431;&#x443;&#x434;&#x435;&#x442; &#x438;&#x43c;&#x435;&#x442;&#x44c; &#x441;&#x43b;&#x435;&#x434;&#x443;&#x44e;&#x449;&#x438;&#x435; &#x43f;&#x43e;&#x43b;&#x44f;: &#xa;&lt;br&gt; &lt;b&gt;BookID&lt;/b&gt; - &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x44b;&#x439; &#x438;&#x434;&#x435;&#x43d;&#x442;&#x438;&#x444;&#x438;&#x43a;&#x430;&#x446;&#x438;&#x43e;&#x43d;&#x43d;&#x44b;&#x439; &#x43d;&#x43e;&#x43c;&#x435;&#x440; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; &#x43f;&#x435;&#x440;&#x432;&#x438;&#x447;&#x43d;&#x44b;&#x43c; &#x43a;&#x43b;&#x44e;&#x447;&#x43e;&#x43c;, &#x43e; &#x43a;&#x43e;&#x442;&#x43e;&#x440;&#x44b;&#x445; &#x43c;&#x44b; &#x43f;&#x43e;&#x433;&#x43e;&#x432;&#x43e;&#x440;&#x438;&#x43c; &#x434;&#x430;&#x43b;&#x435;&#x435;.&#xa;&lt;br&gt; &lt;b&gt;Title&lt;/b&gt; - &#x43d;&#x430;&#x437;&#x432;&#x430;&#x43d;&#x438;&#x435; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x412; &#x44d;&#x442;&#x43e;&#x43c; &#x43f;&#x43e;&#x43b;&#x435; &#x43c;&#x44b; &#x431;&#x443;&#x434;&#x435;&#x43c; &#x437;&#x430;&#x43f;&#x438;&#x441;&#x44b;&#x432;&#x430;&#x442;&#x44c; &#x43d;&#x430;&#x437;&#x432;&#x430;&#x43d;&#x438;&#x435; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x422;&#x438;&#x43f;&#x43e;&#x43c; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x445; &#x44d;&#x442;&#x43e;&#x433;&#x43e; &#x43f;&#x43e;&#x43b;&#x44f; &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; TEXT - &#x441;&#x442;&#x430;&#x43d;&#x434;&#x430;&#x440;&#x442;&#x43d;&#x44b;&#x439; &#x442;&#x438;&#x43f; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x445; &#x432; &#x421;&#x423;&#x411;&#x414; PostgreSQL.&#xa;&lt;br&gt; &lt;b&gt;AuthorID&lt;/b&gt; - &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x44b;&#x439; &#x438;&#x434;&#x435;&#x43d;&#x442;&#x438;&#x444;&#x438;&#x43a;&#x430;&#x446;&#x438;&#x43e;&#x43d;&#x43d;&#x44b;&#x439; &#x43d;&#x43e;&#x43c;&#x435;&#x440; &#x430;&#x432;&#x442;&#x43e;&#x440;&#x430; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; &#x432;&#x43d;&#x435;&#x448;&#x43d;&#x438;&#x43c; &#x43a;&#x43b;&#x44e;&#x447;&#x43e;&#x43c;, &#x43e; &#x43a;&#x43e;&#x442;&#x43e;&#x440;&#x44b;&#x445; &#x43c;&#x44b; &#x43f;&#x43e;&#x433;&#x43e;&#x432;&#x43e;&#x440;&#x438;&#x43c; &#x434;&#x430;&#x43b;&#x435;&#x435;.&#xa;&lt;br&gt; &lt;b&gt;GenreID&lt;/b&gt; - &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x44b;&#x439; &#x438;&#x434;&#x435;&#x43d;&#x442;&#x438;&#x444;&#x438;&#x43a;&#x430;&#x446;&#x438;&#x43e;&#x43d;&#x43d;&#x44b;&#x439; &#x43d;&#x43e;&#x43c;&#x435;&#x440; &#x436;&#x430;&#x43d;&#x440;&#x430; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x442;&#x430;&#x43a;&#x436;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; &#x432;&#x43d;&#x435;&#x448;&#x43d;&#x438;&#x43c; &#x43a;&#x43b;&#x44e;&#x447;&#x43e;&#x43c;, &#x43a;&#x430;&#x43a; &#x438; &#x43f;&#x43e;&#x43b;&#x435; AuthorID.&#xa;&lt;br&gt; &lt;b&gt;PublisherID&lt;/b&gt; - &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x439;&#x44b; &#x438;&#x434;&#x435;&#x43d;&#x442;&#x438;&#x444;&#x438;&#x43a;&#x430;&#x446;&#x438;&#x43e;&#x43d;&#x43d;&#x44b;&#x439; &#x43d;&#x43e;&#x43c;&#x435;&#x440; &#x438;&#x437;&#x434;&#x430;&#x442;&#x435;&#x43b;&#x44c;&#x441;&#x442;&#x432;&#x430;. &#x410;&#x43d;&#x430;&#x43b;&#x43e;&#x433;&#x438;&#x447;&#x43d;&#x43e; &#x43f;&#x43e;&#x43b;&#x44e; AuthorID - &#x44f;&#x432;&#x43b;&#x44f;&#x435;&#x442;&#x441;&#x44f; &#x432;&#x43d;&#x435;&#x448;&#x43d;&#x438;&#x43c; &#x43a;&#x43b;&#x44e;&#x447;&#x43e;&#x43c;.&#xa;&lt;br&gt; &lt;b&gt;YearPublished&lt;/b&gt; - &#x434;&#x430;&#x442;&#x430; &#x43f;&#x443;&#x431;&#x43b;&#x438;&#x43a;&#x430;&#x446;&#x438;&#x438; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x438;&#x43c;&#x435;&#x442;&#x44c; &#x442;&#x438;&#x43f; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x445; DATE.&#xa;&lt;br&gt; &lt;b&gt;ISBN&lt;/b&gt; - &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x44b;&#x439; &#x441;&#x435;&#x440;&#x438;&#x439;&#x43d;&#x44b;&#x439; &#x43d;&#x43e;&#x43c;&#x435;&#x440; &#x43a;&#x43d;&#x438;&#x433;&#x438;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x442;&#x430;&#x43a;&#x436;&#x435;, &#x43a;&#x430;&#x43a; BookID &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; &#x443;&#x43d;&#x438;&#x43a;&#x430;&#x43b;&#x44c;&#x43d;&#x44b;&#x43c;, &#x43e;&#x434;&#x43d;&#x430;&#x43a;&#x43e; &#x43d;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x44f;&#x432;&#x43b;&#x44f;&#x442;&#x44c;&#x441;&#x44f; &#x43f;&#x435;&#x440;&#x432;&#x438;&#x447;&#x43d;&#x44b;&#x43c; &#x43a;&#x43b;&#x44e;&#x447;&#x43e;&#x43c;. &#x422;&#x438;&#x43f; &#x43f;&#x43e;&#x43b;&#x44f; - INTEGER.&#xa;&lt;br&gt; &lt;b&gt;Quantity&lt;/b&gt; - &#x43a;&#x43e;&#x43b;&#x438;&#x447;&#x435;&#x441;&#x442;&#x432;&#x43e; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x445; &#x43a;&#x43d;&#x438;&#x433; &#x432; &#x431;&#x438;&#x431;&#x43b;&#x438;&#x43e;&#x442;&#x435;&#x43a;&#x435;. &#x42d;&#x442;&#x43e; &#x43f;&#x43e;&#x43b;&#x435; &#x431;&#x443;&#x434;&#x435;&#x442; &#x438;&#x43c;&#x435;&#x442;&#x44c; &#x442;&#x438;&#x43f; &#x434;&#x430;&#x43d;&#x43d;&#x44b;&#x445; - INTEGER. &#x410;&#x43d;&#x430;&#x43b;&#x43e;&#x433;&#x438;&#x447;&#x43d;&#x43e; &#x43f;&#x43e;&#x43b;&#x44e; ISBN.&#xa;&#xa;&lt;/html&gt;"/>
